---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: bundles } = await supabase.from('bundles').select('slug');
  return bundles?.map((bundle) => ({
    params: { slug: bundle.slug },
  })) || [];
}

const { slug } = Astro.params;

// Fetch full bundle data
const { data: bundle, error } = await supabase
  .from('bundles')
  .select('*')
  .eq('slug', slug)
  .single();

if (error || !bundle) {
  return Astro.redirect('/404');
}
---

<Layout title={`${bundle.name} — Ingeniería Extrema Media`}>
  <Navbar />

  <main>
    <!-- BUNDLE HERO -->
    <section id="bundle-hero" style="background: linear-gradient(to bottom, #080808 0%, #0f0f0f 100%); padding: 140px 40px 80px; text-align: center;">
      <div style="max-width: 1000px; margin: 0 auto;">
        <div class="section-label" style="color: var(--gold);">{bundle.hero_content?.over || 'COLECCIÓN COMPLETA'}</div>
        <h1 style="font-size: clamp(40px, 8vw, 90px); line-height: 1; margin: 24px 0;">{bundle.hero_content?.title || bundle.name}</h1>
        <p class="hero-sub">{bundle.hero_content?.sub || 'Acceso premium a lo mejor de AEC Resources.'}</p>

        <!-- BUNDLE STATS -->
        <div class="value-bar" style="border-color: rgba(212, 168, 67, 0.2); background: rgba(212, 168, 67, 0.03);">
          {(bundle.stats || []).map((stat, index) => (
            <>
              <div class="value-item">
                <span style="font-size: 20px;">{stat.icon || stat.val}</span> {stat.text || stat.label}
              </div>
              {index < (bundle.stats || []).length - 1 && <div class="value-sep"></div>}
            </>
          ))}
        </div>

        <div style="background: var(--card); border: 1px solid var(--border); padding: 40px; border-radius: 20px; display: inline-block;">
          <div style="display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 24px;">
            <div style="text-align: left;">
              <div style="color: var(--muted); text-decoration: line-through; font-size: 18px;">${bundle.price_total?.toLocaleString() || '0'}</div>
              <div style="font-size: 48px; font-family: var(--font-display); color: var(--green);">${bundle.price_discount?.toLocaleString() || '0'}</div>
            </div>
             <div style="background: var(--red); color: var(--white); padding: 8px 16px; border-radius: 4px; font-weight: 900; font-family: var(--font-mono);">{bundle.saving_percentage}% OFF</div>
          </div>
          <a href={`https://wa.me/19292100867?text=Hola! Quiero el ${bundle.name} en oferta`} target="_blank" class="btn-buy-giant">
            ADQUIRIR BUNDLE COMPLETO
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" style="background: var(--black); padding: 100px 40px; border-top: 1px solid var(--border);">
       <div style="max-width: 800px; margin: 0 auto;">
        <div class="section-label">Resolviendo dudas</div>
        <h2 style="margin-bottom: 48px;">SOBRE EL <span class="accent">BUNDLE</span></h2>
        
        <div class="faq-list" style="display: flex; flex-direction: column; gap: 16px;">
          {(bundle.faq || []).map((item) => (
            <div style="background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 24px; text-align: left;">
              <h3 style="font-size: 17px; margin-bottom: 12px; color: var(--white); font-family: var(--font-body);">{item.q}</h3>
              <p style="font-size: 15px; color: var(--subtle); line-height: 1.6;">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .hero-sub {
    font-size: 18px;
    color: var(--subtle);
    max-width: 700px;
    margin: 0 auto 48px;
    line-height: 1.6;
  }

  .value-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 20px 40px;
    border: 1px solid var(--border);
    border-radius: 100px;
    margin: 0 auto 60px;
    flex-wrap: wrap;
    max-width: fit-content;
  }

  .value-item { display: flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 13px; color: var(--white); }
  .value-sep { width: 1px; height: 20px; background: rgba(255, 255, 255, 0.1); }

  .btn-buy-giant {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--green);
    color: var(--black);
    padding: 24px 50px;
    border-radius: 8px;
    font-size: 20px;
    font-weight: 800;
    text-decoration: none;
    transition: 0.3s;
    box-shadow: 0 0 40px rgba(61, 220, 132, 0.2);
    font-family: var(--font-body);
  }

  .btn-buy-giant:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 10px 50px rgba(61, 220, 132, 0.4); }

  @media (max-width: 900px) {
    .value-bar { border-radius: 20px; }
  }
</style>
