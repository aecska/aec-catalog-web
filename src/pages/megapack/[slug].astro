---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';

export async function getStaticPaths() {
  const { data: packs } = await supabase.from('packs').select('slug');
  return packs?.map((pack) => ({
    params: { slug: pack.slug },
  })) || [];
}

const { slug } = Astro.params;

// Fetch full pack data
const { data: pack, error } = await supabase
  .from('packs')
  .select(`
    *,
    categories (
      name,
      accent_color
    )
  `)
  .eq('slug', slug)
  .single();

if (error || !pack) {
  return Astro.redirect('/404');
}

// URL helpers
const getDirectUrl = (url) => {
  if (!url) return '';
  if (url.includes('drive.google.com')) {
    return url.replace('file/d/', 'uc?id=').split('/view')[0];
  }
  return url;
};
---

<Layout title={`${pack.name} — Ingeniería Extrema Media`}>
  <Navbar />

  <main>
    <!-- HERO SECTION -->
    <section id="hero">
      <div class="hero-content">
        <div class="hero-header-row">
          <div class="software-label">BIBLIOTECA DE {pack.categories.name} PRO</div>
          <div class="stars-social">
            <span class="stars">★★★★★</span>
            <span class="votes">(4.9/5)</span>
          </div>
        </div>
        
        <h1 set:html={pack.name.replace('REVIT', '<span class="accent">REVIT</span>').replace('7.0', '<span class="gray">7.0</span>')} />
        
        <p class="hero-sub">{pack.short_desc}</p>

        <!-- VALUE BAR (DYNAMIC STATS) -->
        <div class="value-bar">
          {pack.hero_stats.map((stat, index) => (
            <>
              <div class="value-item">
                <span>{stat.icon}</span> {stat.text}
              </div>
              {index < pack.hero_stats.length - 1 && <div class="value-sep"></div>}
            </>
          ))}
        </div>

        <div class="hero-actions">
          <a href={`https://wa.me/19292100867?text=Hola! Me interesa el ${pack.name} de $${pack.price.toLocaleString()}`} target="_blank" class="btn-buy-giant">
            Obtener Pack Completo
          </a>
          <div class="trust-signal">
            <span>🔒</span> Pago seguro 100% garantizado
          </div>
        </div>
      </div>
    </section>

    <!-- DASHBOARD / CONTENT GRID -->
    <section id="dashboard">
      <div class="dashboard-container">
        <div class="dashboard-header">
          <div class="section-label">¿Qué estás adquiriendo?</div>
          <h2>ESTE PACK ES EL <span class="accent">RESULTADO</span> DE AÑOS DE FILTRADO</h2>
        </div>

        <div class="content-grid">
          {pack.content_cards.map((card) => (
            <div class={`content-card ${card.type === 'drive' ? 'featured' : ''}`}>
               <div class="card-title">
                {card.type === 'catalog' && '📁'}
                {card.type === 'video' && '🎥'}
                {card.type === 'drive' && '🚀'}
                {card.label}
              </div>
              <p class="card-desc">Haz clic para ver una vista previa real del contenido antes de comprar.</p>
              <div class="dashboard-actions" style="margin-top: auto;">
                 <a href={card.url} target="_blank" class={`btn-action-modal ${card.type === 'drive' ? 'primary' : ''}`}>
                  Ver {card.label}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- BENEFITS -->
    <section id="benefits" style="background: var(--black); padding: 80px 40px; border-top: 1px solid var(--border);">
      <div style="max-width: 1200px; margin: 0 auto;">
        <div class="section-label">Beneficios Exclusivos</div>
        <h2 style="margin-bottom: 40px;">¿POR QUÉ ELEGIR <span class="accent">AEC RESOURCES</span>?</h2>
        
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; text-align: left;">
          {pack.benefits.map((benefit) => (
            <div style="display: flex; gap: 12px; align-items: center; background: var(--card); padding: 20px; border-radius: 8px; border: 1px solid var(--border);">
              <span style="color: var(--green); font-weight: 900;">✔</span>
              <span style="font-size: 14px; color: var(--light);">{benefit}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" style="background: var(--dark); padding: 100px 40px; border-top: 1px solid var(--border);">
       <div style="max-width: 800px; margin: 0 auto;">
        <div class="section-label">Resolviendo dudas</div>
        <h2 style="margin-bottom: 48px;">PREGUNTAS <span class="accent">FRECUENTES</span></h2>
        
        <div class="faq-list" style="display: flex; flex-direction: column; gap: 16px;">
          {pack.faq.map((item) => (
            <div style="background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 24px; text-align: left;">
              <h3 style="font-size: 17px; margin-bottom: 12px; color: var(--white); font-family: var(--font-body);">{item.q}</h3>
              <p style="font-size: 15px; color: var(--subtle); line-height: 1.6;">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  #hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 40px 80px;
    text-align: center;
    background: radial-gradient(circle at center, rgba(61, 220, 132, 0.05) 0%, transparent 70%);
  }

  .hero-content {
    max-width: 1200px;
  }

  .hero-header-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .software-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--green);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .software-label::before, .software-label::after {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--green);
  }

  .stars-social { display: flex; align-items: center; gap: 6px; }
  .stars { color: #d4a843; font-size: 14px; }
  .votes { color: var(--subtle); font-size: 13px; font-weight: 300; }

  h1 {
    font-size: clamp(40px, 7.5vw, 100px);
    line-height: 0.95;
    letter-spacing: -2px;
    color: var(--white);
    margin-bottom: 32px;
  }

  .hero-sub {
    font-size: 17px;
    color: var(--subtle);
    font-weight: 300;
    line-height: 1.7;
    max-width: 850px;
    margin: 0 auto 44px;
  }

  .value-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 20px 40px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 100px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .value-item { display: flex; align-items: center; gap: 8px; font-family: var(--font-mono); font-size: 13px; color: var(--white); }
  .value-sep { width: 1px; height: 20px; background: rgba(255, 255, 255, 0.1); }

  .btn-buy-giant {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--green);
    color: var(--black);
    padding: 24px 50px;
    border-radius: 8px;
    font-size: 20px;
    font-weight: 800;
    text-decoration: none;
    transition: 0.3s;
    box-shadow: 0 0 40px rgba(61, 220, 132, 0.2);
    font-family: var(--font-body);
  }

  .btn-buy-giant:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 10px 50px rgba(61, 220, 132, 0.4); }

  .trust-signal { margin-top: 16px; font-size: 13px; color: var(--subtle); display: flex; align-items: center; justify-content: center; gap: 8px; }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 60px;
    text-align: left;
  }

  .content-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    padding: 40px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    min-height: 280px;
    transition: 0.3s;
  }

  .content-card:hover { border-color: var(--green); transform: translateY(-5px); }
  .content-card.featured { border-color: rgba(61, 220, 132, 0.4); background: rgba(61, 220, 132, 0.03); }

  .card-title { font-family: var(--font-display); font-size: 24px; margin-bottom: 16px; color: var(--white); display: flex; gap: 12px; align-items: center; }
  .card-desc { font-size: 14px; color: var(--subtle); line-height: 1.5; }

  .btn-action-modal {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--white);
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: 0.2s;
  }

  .btn-action-modal:hover { background: var(--mid); }
  .btn-action-modal.primary { background: var(--green); color: var(--black); border-color: var(--green); }

  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .hero-header-row { flex-direction: column; }
    .value-bar { border-radius: 20px; }
  }
</style>
