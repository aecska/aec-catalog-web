---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import CatalogHero from '../components/catalog/CatalogHero.astro';
import CategoryFilters from '../components/catalog/CategoryFilters.astro';
import CatalogUpsell from '../components/catalog/CatalogUpsell.astro';
import ProductCard from '../components/shared/ProductCard.astro';
import { supabase } from '../lib/supabase';

// Fetch all packs with categories for filtering
const { data: packs, error } = await supabase
  .from('packs')
  .select('*, categories(*)')
  .order('created_at', { ascending: false });

---

<Layout title="Catálogo Mega Packs PRO — AEC Resources">
  <Navbar />
  
  <main>
    <CatalogHero />
    <CategoryFilters />

    <section id="catalog-grid-section">
      <div class="container">
        <div class="products-grid" id="catalogGrid">
          {packs && packs.map((pack) => (
            <div class="product-card-wrapper fade-up" data-category={pack.categories?.slug || 'other'}>
              <ProductCard {...pack} />
            </div>
          ))}
        </div>

        {/* Empty State (Hidden by default) */}
        <div id="empty-state" class="empty-state" style="display: none;">
          <div class="empty-icon">📂</div>
          <h3>No se encontraron packs</h3>
          <p>Lo sentimos, no tenemos packs disponibles en esta categoría por el momento. ¡Vuelve pronto!</p>
        </div>
      </div>
    </section>

    <CatalogUpsell />
  </main>

  <Footer />
</Layout>

<style>
  main {
    background: #000;
    min-height: 100vh;
  }

  #catalog-grid-section {
    padding: 60px 40px 80px;
    background: #000;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    min-height: 200px;
  }

  .product-card-wrapper {
    transition: all 0.4s cubic-bezier(0.2, 1, 0.3, 1);
    opacity: 1;
    transform: translateY(0);
  }

  .empty-state {
    padding: 120px 0;
    text-align: center;
    color: #444;
    font-family: var(--font-body);
    border: 1px dashed rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    grid-column: 1 / -1;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  .empty-state h3 {
    color: var(--white);
    font-size: 20px;
    margin-bottom: 12px;
  }

  .empty-state p {
    font-size: 14px;
    max-width: 400px;
    margin: 0 auto;
    color: #666;
  }

  @media (max-width: 1300px) {
    .products-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 1100px) {
    .products-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 800px) {
    .products-grid { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px;
    }
    #catalog-grid-section { padding: 40px 15px; }
  }

  @media (max-width: 600px) {
    .products-grid { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px;
    }
    #catalog-grid-section { padding: 30px 20px; }
  }
</style>

<script>
  // Animation for cards on arrival
  function initCatalogAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  }

  initCatalogAnimations();
  document.addEventListener('astro:after-swap', initCatalogAnimations);
</script>
