---
import { supabase } from '../lib/supabase';

const bundles = [
  {
    name: 'Bundle Revit Total',
    description: 'Acceso total a los 7 packs de Revit. Incluye todas las familias de mobiliario, vegetación, iluminación y plantillas profesionales.',
    price_normal: 52,
    price_promo: 39,
    is_featured: true
  },
  {
    name: 'Bundle AutoCAD Pro',
    description: 'Lleva los 3 packs de AutoCAD con bloques dinámicos, detalles constructivos y plantillas especializadas para arquitectura.',
    price_normal: 22,
    price_promo: 17,
    is_featured: false
  }
];
---

<section id="bundles">
  <div class="section-label">Colecciones completas</div>
  <h2>Lleva la colección completa<br />y ahorra</h2>
  <p class="section-sub">¿Por qué comprar uno solo cuando puedes llevarte toda la colección?</p>

  <div class="bundles-grid">
    {bundles && bundles.map((bundle) => (
      <div class={`bundle-card fade-up ${bundle.is_featured ? 'featured' : ''}`}>
        {bundle.is_featured && <span class="featured-badge">MÁS VENDIDO</span>}
        <div class="bundle-name">{bundle.name}</div>
        <p class="bundle-desc">{bundle.description}</p>
        <div class="bundle-pricing">
          {bundle.price_normal && <span class="price-old">${bundle.price_normal}</span>}
          <span class="price-new"><sup>$</sup>{bundle.price_promo || bundle.price}</span>
          <span class="savings-tag">AHORRAS {Math.round((1 - (bundle.price_promo / bundle.price_normal)) * 100)}%</span>
        </div>
        <div class="bundle-btns">
          <a href={`https://wa.me/19292100867?text=Hola! Quiero detalles del ${bundle.name}`} target="_blank" class="btn-bundle-secondary">Ver detalles</a>
          <a href={`https://wa.me/19292100867?text=Hola! Quiero comprar el ${bundle.name}`} target="_blank" class="btn-bundle">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Comprar
          </a>
        </div>
      </div>
    ))}

    {(!bundles || bundles.length === 0) && (
      <div class="empty-bundles">Próximamente nuevas colecciones.</div>
    )}
  </div>
</section>

<style>
  #bundles {
    background: var(--dark);
    padding: 100px 40px;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .bundles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .bundle-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s, border-color 0.25s;
    text-align: left;
    display: flex;
    flex-direction: column;
  }

  .bundle-card:hover {
    transform: translateY(-4px);
    border-color: rgba(61, 220, 132, 0.25);
  }

  .bundle-card.featured {
    border-color: rgba(61, 220, 132, 0.3);
    background: linear-gradient(135deg, rgba(61, 220, 132, 0.05) 0%, var(--card) 60%);
  }

  .featured-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--green);
    color: var(--black);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    padding: 4px 10px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  .bundle-name {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--white);
    margin-bottom: 8px;
    letter-spacing: 1px;
  }

  .bundle-desc {
    font-size: 13px;
    color: var(--subtle);
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .bundle-pricing {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    margin-bottom: 24px;
  }

  .price-old {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--muted);
    text-decoration: line-through;
  }

  .price-new {
    font-family: var(--font-display);
    font-size: 42px;
    color: var(--white);
    line-height: 1;
  }

  .price-new sup { font-size: 18px; vertical-align: super; font-family: var(--font-body); }

  .savings-tag {
    background: var(--red);
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 2px;
    letter-spacing: 1px;
  }

  .bundle-btns { display: grid; gap: 8px; }

  .btn-bundle-secondary {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--subtle);
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    border-radius: 3px;
    transition: all 0.2s;
  }

  .btn-bundle-secondary:hover { color: var(--white); border-color: var(--subtle); }

  .btn-bundle {
    background: #25d366;
    color: var(--black);
    padding: 14px;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .empty-bundles { grid-column: 1 / -1; color: var(--subtle); font-family: var(--font-mono); margin-top: 40px; }

  @media (max-width: 1100px) { .bundles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .bundles-grid { grid-template-columns: 1fr; } }
</style>
