---
interface Props {
  name: string;
  slug: string;
  price: number;
  old_price?: number;
  image_url: string;
  badge?: string;
  category?: string;
  categories?: {
    name: string;
    accent_color: string;
  };
}

const { name, slug, price, old_price, image_url, badge, category, categories } = Astro.props;

// Usar el nombre de la categoría del objeto unido, o el string legacy, o nada
const displayCategory = categories?.name || category || '';

// Convert format from Drive URL to direct view link if needed
const directImageUrl = (image_url && typeof image_url === 'string' && image_url.includes('drive.google.com'))
  ? image_url.replace('file/d/', 'uc?id=').split('&')[0].split('/view')[0]
  : (image_url || '');
---

<a href={`/megapack/${slug}`} class="product-card">
  <div class="card-img">
    <img src={directImageUrl} alt={name} loading="lazy" />
    {badge && <div class="card-badge-new">{badge}</div>}
    <div class="card-tag">{displayCategory}</div>
  </div>
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    <div class="card-footer">
      <div class="price">
        <sup>$</sup>{price.toLocaleString()}
      </div>
      <div class="card-btns">
        <span class="btn-card">Detalles</span>
      </div>
    </div>
  </div>
</a>

<style>
  .product-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    cursor: pointer;
    text-decoration: none;
    display: block;
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(61, 220, 132, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
  }

  .card-img {
    aspect-ratio: 16/10;
    background: var(--mid);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .card-img img {
    transform: scale(1.05);
  }

  .card-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(8, 8, 8, 0.85);
    padding: 4px 10px;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--white);
  }

  .card-badge-new {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--green);
    color: var(--black);
    padding: 3px 9px;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .card-body {
    padding: 20px;
  }

  .card-name {
    font-weight: 700;
    font-size: 15px;
    color: var(--white);
    margin-bottom: 12px;
    text-align: left;
    font-family: var(--font-body);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .price {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--white);
    letter-spacing: 1px;
    text-align: left;
  }

  .price sup {
    font-size: 14px;
    vertical-align: super;
    font-family: var(--font-body);
    font-weight: 500;
  }

  .btn-card {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--white);
    padding: 8px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-radius: 3px;
    transition: background 0.2s, border-color 0.2s;
  }

  .product-card:hover .btn-card {
    background: var(--mid);
    border-color: var(--subtle);
  }
</style>
