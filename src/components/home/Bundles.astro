---
import { supabase } from '../../lib/supabase';

const { data: bundles, error } = await supabase
  .from('bundles')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(4);
---

<section id="bundles">
  <div class="section-label">
    <span class="line">———</span> COLECCIONES COMPLETAS <span class="line">———</span>
  </div>
  <h2>LLEVA LA COLECCIÓN COMPLETA<br />Y AHORRA</h2>
  <p class="section-sub">¿Por qué comprar uno solo cuando puedes llevarte toda la colección?</p>

  <div class="bundles-grid">
    {bundles && bundles.map((bundle) => (
      <div class={`bundle-card fade-up ${bundle.price_discount > 30 ? 'featured' : ''}`}>
        {bundle.price_discount > 30 && <span class="featured-badge">MÁS VENDIDO</span>}
        <div class="bundle-name">{bundle.name}</div>
        <p class="bundle-desc">{bundle.hero_content?.sub || 'Acceso total a la colección AEC.'}</p>
        <div class="bundle-pricing">
          <div class="pricing-top">
            {bundle.price_total && <span class="price-old">${bundle.price_total}</span>}
            <span class="price-new"><sup>$</sup>{bundle.price_discount}</span>
            <span class="savings-tag">AHORRAS {bundle.saving_percentage}%</span>
          </div>
        </div>
        <div class="bundle-btns">
          <a href={`https://wa.me/19292100867?text=Hola! Quiero detalles del ${bundle.name}`} target="_blank" class="btn-bundle-secondary">VER DETALLES</a>
          <a href={`https://wa.me/19292100867?text=Hola! Quiero comprar el ${bundle.name}`} target="_blank" class="btn-bundle">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Comprar
          </a>
        </div>
      </div>
    ))}

    {(!bundles || bundles.length === 0) && (
      <div class="empty-bundles">Próximamente nuevas colecciones.</div>
    )}
  </div>

  <div class="bundles-footer fade-up">
    <a href="/bundles" class="view-all">
      Ver todas las colecciones →
    </a>
  </div>
</section>

<style>
  #bundles {
    background: var(--dark);
    padding: 100px 40px 120px;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  .bundles-footer {
    display: flex;
    justify-content: center;
    margin-top: 60px;
  }

  .view-all {
    background: rgba(255, 255, 255, 0.05);
    color: var(--white);
    padding: 16px 36px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .view-all:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(61, 220, 132, 0.5);
    color: var(--green);
  }

  .bundles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .bundle-card {
    background: #0d0d0d;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 40px 32px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .bundle-card:hover {
    transform: translateY(-8px);
    border-color: rgba(61, 220, 132, 0.2);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
  }

  /* Glow effect for featured items */
  .bundle-card.featured::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 0% 0%, rgba(61, 220, 132, 0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  .bundle-card.featured {
    border-top: 1px solid rgba(61, 220, 132, 0.4);
    border-left: 1px solid rgba(61, 220, 132, 0.2);
  }

  .featured-badge {
    position: absolute;
    top: 24px;
    right: 24px;
    background: #3ddc84;
    color: #000;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.5px;
    padding: 4px 12px;
    border-radius: 3px;
    text-transform: uppercase;
    z-index: 2;
  }

  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .section-label .line {
    opacity: 0.3;
    font-weight: 300;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 70px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 24px;
    text-transform: uppercase;
    text-align: center;
  }

  .section-sub {
    color: #888;
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.5;
    max-width: 650px;
    margin: 0 auto 60px;
    text-align: center;
  }

  .bundle-name {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--white);
    margin-bottom: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .bundle-desc {
    font-size: 14px;
    color: #888;
    line-height: 1.6;
    margin-bottom: 32px;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bundle-pricing {
    margin-bottom: 32px;
  }

  .pricing-top {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .price-old {
    font-family: var(--font-body);
    font-size: 16px;
    color: #444;
    text-decoration: line-through;
    font-weight: 500;
  }

  .price-new {
    font-family: var(--font-display);
    font-size: 48px;
    color: var(--white);
    line-height: 1;
    font-weight: 800;
  }

  .price-new sup { 
    font-size: 20px; 
    vertical-align: super; 
    font-family: var(--font-display); 
    margin-right: 2px;
  }

  .savings-tag {
    background: #ff4b4b;
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 800;
    padding: 4px 12px;
    border-radius: 4px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .bundle-btns { 
    display: grid; 
    grid-template-columns: auto 1fr; 
    align-items: center;
    gap: 20px;
    margin-top: auto; 
  }

  .btn-bundle-secondary {
    background: transparent;
    border: none;
    color: #666;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    text-align: left;
    transition: all 0.2s;
    letter-spacing: 1px;
  }

  .btn-bundle-secondary:hover { 
    color: var(--white); 
  }

  .btn-bundle {
    background: #3ddc84;
    color: #000;
    padding: 12px 24px;
    font-weight: 800;
    text-decoration: none;
    text-align: center;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 14px;
    transition: all 0.3s;
  }

  .btn-bundle:hover {
    background: #4de091;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(61, 220, 132, 0.3);
  }

  .empty-bundles { 
    grid-column: 1 / -1; 
    color: #444; 
    font-family: var(--font-mono); 
    margin-top: 40px; 
    font-size: 12px;
  }

  @media (max-width: 1200px) { .bundles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { 
    .bundles-grid { grid-template-columns: 1fr; }
    .bundle-btns { grid-template-columns: 1fr; gap: 12px; }
    .btn-bundle-secondary { text-align: center; }
  }
</style>
