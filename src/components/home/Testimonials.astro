---
// Google Drive IDs provided by the user
const chatScreenshots = [
  '1L_jM6qj-_mJ9ROiuiERqVw5EAuluGMq5',
  '1JA1YnbpZDaSIxQxAHwpTwWA017okZ4Lx',
  '1iXPlah5O-RABeMrPHUWK3JrC2FdRHAkk',
  '1k23uNbJkkMjve0nt7WorA8nrZ7zm4M5E',
  '14ljQbLUmn72SvvnutQeC6km-423jsldc',
  '1YtZtwjk5475M-eLYnLLUOH9b9jOnZism',
  '12Ip4408_wOW1wT7XZfAoqdVl92pdS_CH'
];

const getDirectUrl = (id: string) => `https://lh3.googleusercontent.com/d/${id}`;
---

<section id="testimonials">
  <div class="container">
    <div class="section-intro fade-up">
      <div class="section-label">
        <span class="line">———</span> PRUEBA SOCIAL <span class="line">———</span>
      </div>
      <h2>NO LO DECIMOS NOSOTROS,<br />LO DICEN NUESTROS CHATS</h2>
      <p class="section-sub">Transparencia total. Así entregamos nuestros packs todos los días.</p>
    </div>

    <!-- Scrollable Proof Gallery with Arrows -->
    <div class="proof-gallery-wrapper fade-up">
      <button id="prevBtn" class="proof-btn prev" aria-label="Anterior">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <button id="nextBtn" class="proof-btn next" aria-label="Siguiente">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <div id="proofGallery" class="proof-gallery">
        {chatScreenshots.map((id, index) => (
          <div class="proof-item">
            <div class="proof-card">
              <div class="badge-verified">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                COMPRA VERIFICADA
              </div>
              <img src={getDirectUrl(id)} alt={`Testimonio WhatsApp ${index + 1}`} loading="lazy" />
              <div class="chat-id">WhatsApp Chat #{1024 + index}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initGallery() {
    const gallery = document.getElementById('proofGallery');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');

    if (gallery && prevBtn && nextBtn) {
      const scrollAmount = 350;
      
      prevBtn.onclick = () => {
        gallery.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      };

      nextBtn.onclick = () => {
        gallery.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      };
    }
  }

  // Initialize
  initGallery();
  document.addEventListener('astro:after-swap', initGallery);
</script>

<style>
  #testimonials {
    background: #000;
    padding: 120px 40px;
    text-align: center;
    overflow: hidden;
    position: relative;
  }

  /* Subtitle/Header Standardization */
  .section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--green);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .section-label .line {
    opacity: 0.3;
    font-weight: 300;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 70px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .section-sub {
    color: #888;
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.5;
    max-width: 650px;
    margin: 0 auto 80px;
  }

  .container { max-width: 1400px; margin: 0 auto; }

  .proof-gallery-wrapper {
    position: relative;
    width: 100%;
  }

  .proof-gallery {
    display: flex;
    gap: 32px;
    overflow-x: auto;
    padding: 20px 0 60px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .proof-gallery::-webkit-scrollbar { display: none; }

  .proof-item {
    flex: 0 0 320px;
    scroll-snap-align: center;
    transition: transform 0.4s cubic-bezier(0.2, 1, 0.3, 1);
  }

  .proof-item:hover { transform: translateY(-10px) scale(1.02); }

  .proof-card {
    background: #0d0d0d;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  .badge-verified {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(61, 220, 132, 0.9);
    color: #000;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 5px;
    z-index: 5;
    letter-spacing: 0.5px;
  }

  .proof-card img {
    width: 100%;
    aspect-ratio: 9/16;
    object-fit: cover;
    filter: brightness(0.9) contrast(1.1);
    transition: filter 0.3s;
  }

  .proof-item:hover .proof-card img {
    filter: brightness(1) contrast(1.1);
  }

  .chat-id {
    padding: 15px;
    background: #111;
    color: #444;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    border-top: 1px solid rgba(255,255,255,0.03);
  }

  .proof-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    background: rgba(15, 15, 15, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s;
    backdrop-filter: blur(10px);
  }

  .proof-btn:hover { background: var(--green); color: var(--black); border-color: var(--green); scale: 1.1; }

  .proof-btn.prev { left: -28px; }
  .proof-btn.next { right: -28px; }

  @media (max-width: 1450px) {
    .proof-btn.prev { left: 10px; }
    .proof-btn.next { right: 10px; }
  }

  @media (max-width: 600px) {
    #testimonials { padding: 80px 20px; }
    .proof-item { flex: 0 0 280px; }
    .section-sub { margin-bottom: 40px; }
  }
</style>
