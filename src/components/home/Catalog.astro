---
import { supabase } from '../../lib/supabase';
import ProductCard from '../shared/ProductCard.astro';

// Consultar los 10 packs más destacados (5x2)
const { data: packs, error } = await supabase
  .from('packs')
  .select('*, categories(*)')
  .order('created_at', { ascending: false })
  .limit(10);
---

<section id="catalog">
  <div class="catalog-header fade-up">
    <div class="section-label">Lo más reciente en la tienda</div>
    <h2>Mega Packs Destacados</h2>
    <p class="section-sub">
      Herramientas de alto nivel diseñadas para potenciar tus flujos de trabajo profesionales.
    </p>
  </div>

  <div class="products-grid">
    {packs && packs.map((pack) => (
      <ProductCard {...pack} />
    ))}

    {(!packs || packs.length === 0) && (
      <div class="empty-state">
        <p>No se encontraron packs en este momento. Vuelve pronto.</p>
      </div>
    )}
  </div>

  <div class="catalog-footer fade-up">
    <a href="/megapacks" class="view-all">
      Ver todos los Mega Packs →
    </a>
  </div>
</section>

<style>
  #catalog {
    padding: 120px 40px;
    background: var(--black);
    position: relative;
    z-index: 2;
  }

  .catalog-header {
    max-width: 1100px;
    margin: 0 auto 80px;
    text-align: center;
  }

  .section-label {
    background: rgba(61, 220, 132, 0.1);
    color: var(--green);
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 10px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 24px;
    border: 1px solid rgba(61, 220, 132, 0.2);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 80px);
    line-height: 0.9;
    color: var(--white);
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .section-sub {
    color: #888; /* matched with hero-sub in Hero.astro */
    font-size: clamp(14px, 1.4vw, 16px); /* matched with hero-sub in Hero.astro */
    line-height: 1.5;
    max-width: 650px;
    margin: 0 auto;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    max-width: 1500px;
    margin: 0 auto 60px;
  }

  .empty-state {
    grid-column: 1 / -1;
    padding: 100px 0;
    text-align: center;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 14px;
    border: 1px dashed var(--border);
    border-radius: 8px;
    opacity: 0.5;
  }

  .catalog-footer {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .view-all {
    background: rgba(255, 255, 255, 0.05);
    color: var(--white);
    padding: 16px 36px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .view-all:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(61, 220, 132, 0.5);
    color: var(--green);
  }
  @media (max-width: 1300px) {
    .products-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 1100px) {
    .products-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 800px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    #catalog { padding: 70px 20px; }
  }

  @media (max-width: 600px) {
    .catalog-header { flex-direction: column; align-items: flex-start; gap: 20px; text-align: left; }
    h2 { font-size: 40px; }
    .section-sub { text-align: left; margin: 0; }
    .products-grid { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px;
      margin-bottom: 40px;
    }
    #catalog { padding: 60px 20px; }
  }
</style>
