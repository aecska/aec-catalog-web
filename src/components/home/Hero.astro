---
---

<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <div class="hero-badge fade-up">
      Packs listos para usar: Arquitectura, Ingeniería y Construcción
    </div>
    
    <h1 class="fade-up" style="transition-delay: 0.1s">
      Llegaste al <br />
      <span class="accent">lugar</span> <span class="line2">indicado.</span>
    </h1>

    <p class="hero-sub fade-up" style="transition-delay: 0.2s">
      Nosotros ya filtramos, organizamos y empaquetamos el contenido premium que necesitas.
      <strong>Cero membresías, un solo pago, acceso para siempre.</strong>
    </p>
    
    <div class="hero-actions fade-up" style="transition-delay: 0.3s">
      <div class="hero-main-btns">
        <a href="/megapacks" class="btn-primary">
          Ver los Mega Packs &rarr;
        </a>
      </div>

      <div class="trust-belt">
        <div class="trust-item">
          <span>⚡</span> Acceso inmediato vía Google Drive
        </div>
        <div class="trust-sep">|</div>
        <div class="trust-item">
          <span>🔒</span> Compra segura por WhatsApp
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 70px 40px 0; /* AJUSTE FINO: UN POQUITO MÁS ARRIBA */
    position: relative;
    overflow: hidden;
    background: var(--black);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 30%, rgba(61, 220, 132, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    max-width: 1000px; /* ANCHO DEL DISEÑO ORIGINAL */
    text-align: center;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    background: rgba(61, 220, 132, 0.1);
    color: var(--green);
    padding: 8px 16px; /* PADDING DEL DISEÑO ORIGINAL */
    border-radius: 4px; /* RADIO DEL DISEÑO ORIGINAL */
    border: 1px solid rgba(61, 220, 132, 0.2);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 12vw, 130px); /* MÁS GRANDE */
    line-height: 0.85;
    color: var(--white);
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  h1 .accent {
    color: var(--green);
  }

  h1 .line2 {
    color: #888 !important; /* EL GRIS SOLICITADO */
  }

  .hero-sub {
    font-size: clamp(14px, 1.4vw, 16px); /* BAJA UN POCO */
    color: #888;
    max-width: 600px;
    margin-bottom: 48px;
    line-height: 1.5;
  }

  .hero-sub strong {
    color: var(--white);
    font-weight: 700;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px; /* MÁS PEGADO AL BOTÓN */
    width: 100%;
  }

  .btn-primary {
    background: var(--green);
    color: var(--black);
    padding: 16px 32px; /* PADDING DEL DISEÑO ORIGINAL */
    border-radius: 4px;
    font-weight: 700;
    text-decoration: none;
    font-size: 16px;
    transition: transform 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(61, 220, 132, 0.3);
  }

  .trust-belt {
    display: flex;
    align-items: center;
    gap: 16px;
    color: #555;
    font-size: 11px;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .trust-sep { opacity: 0.3; }

  @media (max-width: 600px) {
    #hero {
      padding-top: 40px;
      height: 90vh;
    }
    h1 { font-size: 48px; }
    .hero-sub { font-size: 14px; }
    .hero-badge { margin-bottom: 24px; padding: 6px 12px; }
    .trust-belt { flex-direction: column; gap: 8px; }
    .trust-sep { display: none; }
  }
</style>
