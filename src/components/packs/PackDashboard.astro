---
interface Props {
  pack: any;
}

const { pack } = Astro.props;
const accentColor = pack.categories?.accent_color || 'var(--green)';

// Fallback content if DB is empty
const defaultCards = [
  { 
    title: '30 PLANTILLAS DE VISTA', 
    description: '10 Plantas (Arqui & Estructura), 10 Secciones Técnicas Profundas, 5 Elevaciones & Sombras, 5 Vistas 3D & Isometrías',
    type: 'catalog'
  },
  { 
    title: '9 CLASES MAGISTRALES', 
    description: '1h 45 min de entrenamiento Pro, Creación de plantillas propias, Configuración de filtros BIM, Estandarización de grosores',
    type: 'video',
    is_featured: true
  },
  { 
    title: 'LIBRERÍA REVIT 2.0', 
    description: 'Refuerzos Estructurales, Componentes de anotación, Tablas de planificación, Acceso a futuras mejoras',
    type: 'drive'
  }
];

const cards = (pack.content_cards && pack.content_cards.length >= 3) ? pack.content_cards : defaultCards;

// Helper to format s2_title (handle line breaks)
const formatS2Title = (text: string) => {
  if (!text) return '';
  return text.replace(/\n/g, '<br />').replace(/\r/g, '');
};

// Helper to split description into checklist items
const getChecklist = (desc: string) => {
  if (!desc) return [];
  return desc.split(',').map(item => item.trim());
};
---

<section id="dashboard">
  <div class="dashboard-container">
    <div class="dashboard-header fade-up">
      <div class="overtitle">— {pack.s2_overtitle || 'DOMINA EL SOFTWARE HOY MISMO'} —</div>
      <h2 set:html={formatS2Title(pack.s2_title || 'TODO LO QUE NECESITAS PARA ENTREGAS PRO EN UN SOLO LUGAR')} />
      <p class="section-sub">
        {pack.s2_subtitle || 'Diseñado para arquitectos que buscan resultados de alto nivel sin perder horas configurando.'}
      </p>
    </div>

    <div class="content-grid">
      {cards.map((card, index) => (
        <div 
          class={`content-card fade-up ${index === 1 || card.is_featured ? 'featured' : ''}`} 
          style={`transition-delay: ${index * 0.1}s; --accent: ${accentColor}`}
        >
          { (index === 1 || card.is_featured) && <div class="featured-tag"></div> }
          
          <div class="card-header">
            <span class="card-icon">
              {card.type === 'catalog' && '📁'}
              {card.type === 'video' && '🎥'}
              {card.type === 'drive' && '🚀'}
              {!card.type && '✨'}
            </span>
            <h3 class="card-title">{card.title || card.label}</h3>
          </div>

          <ul class="card-list">
            {getChecklist(card.description).map((item) => (
              <li>
                <span class="check">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- MAIN DASHBOARD ACTIONS -->
    <div class="dashboard-actions fade-up" style="transition-delay: 0.4s">
      <button class="btn-action secondary open-modal-btn" data-url={pack.catalog_url} data-type="catalog">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        Explorar Catálogo de Elementos
      </button>
      
      <button class="btn-action primary open-modal-btn" data-url={pack.demo_video_url} data-type="video">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z" />
        </svg>
        Ver Video Demostración
      </button>
    </div>
  </div>

  <!-- REUSABLE MODAL -->
  <div id="dashboardModal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <button class="modal-close">&times;</button>
      <div class="video-wrapper">
        <iframe id="modalIframe" src="" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  #dashboard {
    background: #080808;
    padding: 120px 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  .dashboard-container {
    max-width: 1300px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .dashboard-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .overtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--green);
    text-transform: uppercase;
    margin-bottom: 24px;
    opacity: 0.8;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 60px);
    line-height: 1;
    margin-bottom: 28px;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: -1px;
    max-width: 850px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-sub {
    font-size: 17px;
    color: var(--subtle);
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto;
    font-weight: 300;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin: 0 auto 60px;
    max-width: 1050px; /* Make cards smaller by limiting grid width */
  }

  .content-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 32px 24px; /* Reduced padding to make card feel smaller */
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all 0.3s ease;
  }

  .content-card.featured {
    border-color: var(--accent);
    background: rgba(255, 255, 255, 0.03);
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.3), inset 0 0 20px rgba(0, 0, 0, 0.2);
  }

  /* Sublte glow only for featured */
  .content-card.featured::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 16px;
    box-shadow: 0 0 15px var(--accent);
    opacity: 0.2;
    pointer-events: none;
  }

  .featured-tag {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background: var(--accent);
    border-radius: 0 0 4px 4px;
    box-shadow: 0 0 10px var(--accent);
  }

  .card-header {
    margin-bottom: 32px;
  }

  .card-icon {
    font-size: 24px;
    display: block;
    margin-bottom: 16px;
    opacity: 0.9;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-list li {
    font-size: 14px;
    color: var(--white);
    opacity: 0.8;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    line-height: 1.4;
  }

  .check {
    color: var(--accent);
    font-weight: 900;
    font-size: 16px;
  }

  /* ACTIONS BUTTONS AREA */
  .dashboard-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .btn-action {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 32px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    font-family: var(--font-body);
  }

  .btn-action.secondary {
    background: rgba(255, 255, 255, 0.05);
    color: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn-action.primary {
    background: rgba(61, 220, 132, 0.1);
    color: #3ddc84;
    border: 1px solid rgba(61, 220, 132, 0.3);
  }

  .btn-action:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.1);
  }

  .btn-action.primary:hover {
    background: rgba(61, 220, 132, 0.2);
    border-color: #3ddc84;
  }

  /* MODAL STYLES */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .modal.active { display: flex; }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
  }

  .modal-content {
    position: relative;
    width: 100%;
    max-width: 1000px;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.8);
  }

  .modal-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255,255,255,0.1);
    border: none;
    color: white;
    font-size: 30px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    line-height: 1;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .dashboard-actions { flex-direction: column; width: 100%; }
    .btn-action { width: 100%; justify-content: center; }
  }
</style>

<script>
  function initDashboardModal() {
    const modal = document.getElementById('dashboardModal');
    const openBtns = document.querySelectorAll('.open-modal-btn');
    const closeBtn = document.querySelector('.modal-close');
    const overlay = document.querySelector('.modal-overlay');
    const iframe = document.getElementById('modalIframe') as HTMLIFrameElement;

    if (!modal || !iframe) return;

    const toggleModal = (show: boolean, url: string = '') => {
      modal.classList.toggle('active', show);
      if (show && url) {
        let finalUrl = url;
        // Convert Youtube watch to embed if needed
        if (finalUrl.includes('youtube.com/watch?v=')) {
          finalUrl = finalUrl.replace('watch?v=', 'embed/');
        }
        // Ensure Drive links are /preview if they are file links (handle additional query params)
        if (finalUrl.includes('drive.google.com/file/d/')) {
          finalUrl = finalUrl.replace(/\/view(\?.*)?$/, '/preview');
        }
        
        iframe.src = finalUrl;
        document.body.style.overflow = 'hidden';
      } else {
        iframe.src = '';
        document.body.style.overflow = '';
      }
    };

    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const url = btn.getAttribute('data-url') || '';
        if (url && url !== '#') {
          toggleModal(true, url);
        } else {
          alert('Próximamente disponible.');
        }
      });
    });

    closeBtn?.addEventListener('click', () => toggleModal(false));
    overlay?.addEventListener('click', () => toggleModal(false));

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') toggleModal(false);
    });
  }

  initDashboardModal();
  document.addEventListener('astro:after-swap', initDashboardModal);
</script>
