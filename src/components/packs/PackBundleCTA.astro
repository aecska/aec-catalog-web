---
interface Props {
  pack: any;
  bundle: any;
}

const { pack, bundle } = Astro.props;

// Use the category name for the software part
const softwareName = pack.categories?.name || 'este software';
const discount = bundle.saving_percentage || '25';
---

<section id="bundle-cta">
  <div class="cta-gradient">
    <div class="container fade-up">
      <div class="badge">¡OFERTA ESPECIAL!</div>
      <h2>LLEVA TU BIBLIOTECA AL NIVEL DEFINITIVO</h2>
      <p>Añade todos los packs de {softwareName} en nuestro Bundle y ahorra un {discount}%.</p>
      
      <div class="actions">
        <a href={`/bundle/${bundle.slug}`} class="btn-bundle">
          Ver Bundle Completo
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #bundle-cta {
    padding: 0;
    overflow: hidden;
  }

  .cta-gradient {
    background: linear-gradient(135deg, #2980b9 0%, #2c3e50 100%);
    padding: 100px 40px;
    position: relative;
    border-top: 5px solid #000;
    border-bottom: 5px solid #000;
  }

  /* Decorative light flare */
  .cta-gradient::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, transparent 70%);
    transform: rotate(35deg);
    pointer-events: none;
  }

  .container {
    max-width: 950px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.1);
    color: var(--white);
    padding: 8px 16px;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    margin-bottom: 32px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 60px);
    line-height: 1;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 24px;
    letter-spacing: -1px;
  }

  p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 48px;
    font-weight: 300;
  }

  .btn-bundle {
    display: inline-block;
    background: var(--white);
    color: #000;
    padding: 18px 48px;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    font-family: var(--font-body);
  }

  .btn-bundle:hover {
    transform: scale(1.05);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .cta-gradient { padding: 60px 20px; }
    h2 { font-size: 32px; }
  }
</style>
