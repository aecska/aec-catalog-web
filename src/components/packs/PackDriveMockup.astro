---
interface Props {
  pack: any;
}

const { pack } = Astro.props;
const accentColor = pack.categories?.accent_color || 'var(--green)';

const folders = [
  '01_Bibliotecas_Premium',
  '02_Texturas_4K',
  '03_Modelos_3D',
  '04_Guias_Usuario',
  '05_Bonos_Exclusivos'
];
---

<section id="drive-preview">
  <div class="container">
    <div class="drive-grid">
      <div class="drive-text fade-up">
        <div class="section-label">Transparencia Total</div>
        <h2>EXPLORA EL <span style={`color: ${accentColor}`}>GOOGLE DRIVE</span> REAL</h2>
        <p>No vendemos promesas. Vendemos contenido organizado y listo para descargar. Así es como verás tu pack una vez que realices el pago.</p>
        
        <ul class="drive-features">
          <li><span class="dot"></span> Acceso inmediato perpetuo</li>
          <li><span class="dot"></span> Servidores de alta velocidad</li>
          <li><span class="dot"></span> Actualizaciones gratuitas</li>
        </ul>
      </div>

      <div class="browser-frame fade-up" style="transition-delay: 0.2s">
        <div class="browser-header">
          <div class="browser-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="browser-address">
            drive.google.com/u/0/folders/{pack.slug}-premium
          </div>
        </div>

        <div class="browser-content">
          <div class="explorer-toolbar">
            <div class="path-bar">
              Mi unidad > <strong>{pack.categories?.name || 'AEC'}</strong> > {pack.name}
            </div>
          </div>

          <div class="folder-grid">
            {folders.map((folder) => (
              <div class="folder-item">
                <div class="folder-icon">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="rgba(255,255,255,0.2)">
                    <path d="M20 18H4V8h16v10zm0-12h-8l-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                  </svg>
                </div>
                <div class="folder-name">{folder}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #drive-preview {
    padding: 120px 40px;
    background: var(--dark);
    border-top: 1px solid var(--border);
  }

  .container {
    max-width: 950px;
    margin: 0 auto;
  }

  .drive-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 80px;
    align-items: center;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--subtle);
    text-transform: uppercase;
    margin-bottom: 24px;
    display: block;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.1;
    margin-bottom: 24px;
    color: var(--white);
    text-transform: uppercase;
  }

  p {
    font-size: 16px;
    color: var(--subtle);
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .drive-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .drive-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--light);
    font-weight: 600;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px rgba(61, 220, 132, 0.5);
  }

  /* Browser Frame */
  .browser-frame {
    background: #0d0d0d;
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
  }

  .browser-header {
    background: #1a1a1a;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 15px;
    border-bottom: 1px solid var(--border);
  }

  .browser-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .browser-address {
    flex: 1;
    background: #000;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 11px;
    color: #555;
    font-family: var(--font-mono);
  }

  .browser-content {
    background: #0d0d0d;
    min-height: 400px;
  }

  .explorer-toolbar {
    background: #151515;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
  }

  .path-bar {
    font-size: 12px;
    color: #888;
    font-family: var(--font-mono);
  }

  .path-bar strong { color: var(--white); }

  .folder-grid {
    padding: 40px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 20px;
  }

  .folder-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 15px;
    border-radius: 8px;
    transition: 0.2s;
    cursor: default;
  }

  .folder-item:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .folder-name {
    font-size: 11px;
    color: #subtle;
    text-align: center;
    font-family: var(--font-mono);
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .drive-grid { grid-template-columns: 1fr; gap: 60px; }
    #drive-preview { padding: 80px 20px; }
  }
</style>
