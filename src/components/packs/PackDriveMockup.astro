---
interface Props {
  pack: any;
}

const { pack } = Astro.props;
const accentColor = pack.categories?.accent_color || 'var(--green)';

const trustCards = [
  { 
    title: 'Pago Protegido', 
    desc: 'Pasarela 100% segura.', 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>` 
  },
  { 
    title: 'Acceso Cloud', 
    desc: 'Google Drive 24/7.', 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2-1.5-3.5-3.5-4C18 7.5 15.5 5 12.5 5c-2.5 0-4.5 2-4.5 4.5 0 .5.1.8.2 1.2C6 11 4.5 12.5 4.5 14.5c0 2.5 2 4.5 4.5 4.5h8.5z"></path></svg>` 
  },
  { 
    title: 'Link Vitalicio', 
    desc: 'Nunca caduca.', 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>` 
  },
  { 
    title: 'Soporte VIP', 
    desc: 'Chat con ingenieros.', 
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>` 
  }
];

// Helper to handle video URL
const videoUrl = pack.drive_video_url || 'https://www.youtube.com/embed/Zn74CVBgTLQ';
const finalVideoUrl = videoUrl.includes('youtube.com/watch?v=') ? videoUrl.replace('watch?v=', 'embed/') : (videoUrl.includes('drive.google.com/file/d/') && !videoUrl.includes('/preview') ? videoUrl.replace(/\/view(\?.*)?$/, '/preview') : videoUrl);

---

<section id="access-process">
  <div class="container">
    <div class="header fade-up">
      <div class="overtitle">— PROCESO DE ACCESO —</div>
      <h2>TU LIBRERÍA EN LA NUBE, LISTA PARA USAR</h2>
      <p class="subtitle">Acceso inmediato y organizado. Mira cómo navegarás por tu nuevo material.</p>
    </div>

    <div class="access-grid">
      <!-- LEFT: BROWSER VIDEO TOUR -->
      <div class="video-column fade-up">
        <div class="browser-mockup">
          <div class="browser-header">
            <div class="dots">
              <span class="dot red"></span>
              <span class="dot yellow"></span>
              <span class="dot green"></span>
            </div>
            <div class="address-bar">
              <span class="folder-path">Mi Unidad > Tour por el Pack {pack.name}</span>
            </div>
          </div>
          <div class="video-container">
            <iframe src={finalVideoUrl} frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        </div>
      </div>

      <!-- RIGHT: TRUST CARDS -->
      <div class="cards-column">
        {trustCards.map((card, index) => (
          <div class="trust-card fade-up" style={`transition-delay: ${index * 0.1}s`}>
            <div class="card-inner">
              <div class="card-icon" set:html={card.icon} />
              <div class="card-info">
                <h3>{card.title}</h3>
                <p>{card.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #access-process {
    padding: 120px 40px;
    background: #050505;
    position: relative;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }

  .container {
    max-width: 950px;
    margin: 0 auto;
  }

  .header {
    text-align: center;
    margin-bottom: 80px;
  }

  .overtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--green);
    margin-bottom: 24px;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 60px);
    line-height: 1;
    color: var(--white);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .subtitle {
    font-size: 17px;
    color: var(--subtle);
    max-width: 600px;
    margin: 0 auto;
    font-weight: 300;
  }

  .access-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 32px;
    align-items: center;
  }

  /* Browser Mockup Styling */
  .browser-mockup {
    background: #111;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
  }

  .browser-header {
    background: #1a1a1a;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .address-bar {
    background: rgba(0, 0, 0, 0.3);
    padding: 6px 16px;
    border-radius: 4px;
    flex: 1;
  }

  .folder-path {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-mono);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: block;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    background: #000;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* Right Column: Trust Cards */
  .cards-column {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .trust-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 24px;
    transition: all 0.3s ease;
  }

  .trust-card:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.1);
    transform: translateX(8px);
  }

  .card-inner {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .card-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4facfe; /* Blue color from screenshot hints */
    background: rgba(79, 172, 254, 0.1);
    border-radius: 10px;
    flex-shrink: 0;
  }

  .card-info h3 {
    font-size: 16px;
    margin-bottom: 4px;
    color: var(--white);
    font-weight: 700;
  }

  .card-info p {
    font-size: 13px;
    color: var(--subtle);
    margin: 0;
  }

  @media (max-width: 900px) {
    .access-grid { grid-template-columns: 1fr; gap: 40px; }
    .trust-card:hover { transform: translateY(-4px); }
  }
</style>
