---
import { supabase } from '../../lib/supabase';

const { data: bundles, error } = await supabase
  .from('bundles')
  .select('*')
  .order('created_at', { ascending: false });
---

<section class="bundles-catalog-grid">
  <div class="container">
    <div class="grid-layout">
      {bundles && bundles.map((bundle) => (
        <div class={`bundle-card fade-up ${bundle.price_discount > 30 ? 'featured' : ''}`}>
          {bundle.price_discount > 30 && <span class="featured-badge">MÁS VENDIDO</span>}
          
          <h3 class="bundle-title">{bundle.name}</h3>
          <p class="bundle-description">{bundle.hero_subtitle || 'Acceso total a la colección AEC profesional.'}</p>
          
            <div class="bundle-pricing">
              <div class="pricing-row">
                {bundle.price_total && <span class="price-original">${bundle.price_total}</span>}
                <span class="price-current"><sup>$</sup>{bundle.price_discount}</span>
                <span class="price-unit">USD</span>
                <span class="discount-badge">AHORRAS {bundle.saving_percentage}%</span>
              </div>
            </div>

          <div class="bundle-actions">
            <a href={`/bundle/${bundle.slug}`} class="btn-secondary">
              VER DETALLES
            </a>
            <a href={`https://wa.me/573133144700?text=Hola! Quiero comprar el ${bundle.name} completo ($${bundle.price_discount} USD). Por favor envíame los métodos de pago.`} target="_blank" class="btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              Comprar
            </a>
          </div>
        </div>
      ))}
    </div>

    {(!bundles || bundles.length === 0) && (
      <div class="empty-state">
        <p>AEC Collections coming soon.</p>
      </div>
    )}
  </div>
</section>

<style>
  .bundles-catalog-grid {
    padding: 60px 40px 100px;
    background: #000;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .grid-layout {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .bundle-card {
    background: #0d0d0d;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 32px 24px; /* Optimizado para ganar espacio */
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .bundle-card:hover {
    transform: translateY(-8px);
    border-color: rgba(61, 220, 132, 0.2);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
  }

  .bundle-card.featured {
    border-top: 2px solid var(--green);
    background: linear-gradient(to bottom, rgba(61, 220, 132, 0.03), #0d0d0d);
  }

  .featured-badge {
    position: absolute;
    top: 24px;
    right: 24px;
    background: var(--green);
    color: #000;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 2px;
    text-transform: uppercase;
    z-index: 2;
  }

  .bundle-title {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--white);
    margin-bottom: 12px;
    line-height: 1;
    text-transform: uppercase;
  }

  .bundle-description {
    font-size: 14px;
    color: #888;
    line-height: 1.6;
    margin-bottom: 30px;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bundle-pricing {
    margin-bottom: 32px;
  }

  .pricing-row {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }

  .price-original {
    color: #444;
    text-decoration: line-through;
    font-size: 14px;
    font-family: var(--font-body);
  }

  .price-current {
    font-family: var(--font-display);
    font-size: 42px;
    color: var(--white);
    line-height: 1;
    font-weight: 800;
  }

  .price-current sup {
    font-size: 18px;
    vertical-align: super;
    font-family: var(--font-display);
  }

  .price-unit {
    font-size: 11px;
    color: #666;
    font-weight: 600;
    margin-left: 2px;
  }

  .discount-badge {
    background: #ff4b4b;
    color: var(--white);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .bundle-actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
  }

  .btn-secondary {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #666;
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.2s;
    white-space: nowrap !important; /* Blindaje absoluto */
    flex-shrink: 0;
    min-width: max-content;
  }

  .btn-secondary:hover {
    border-color: #444;
    color: var(--white);
  }

  .btn-primary {
    flex: 1.5;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: #25d366;
    color: #000;
    padding: 14px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    border-radius: 4px;
    text-decoration: none;
    transition: 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .empty-state {
    text-align: center;
    padding: 100px 0;
    color: #444;
    font-family: var(--font-mono);
  }

  @media (max-width: 900px) {
    .grid-layout { 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12px;
    }
    .bundles-catalog-grid { padding: 40px 15px; }
    .bundle-card { padding: 20px 15px; }
    
    .bundle-title { font-size: 22px; }
    .price-current { font-size: 32px; }
    .bundle-actions { flex-direction: column; }
    .btn-secondary, .btn-primary { width: 100%; text-align: center; font-size: 11px; }
  }

  @media (max-width: 600px) {
    .bundles-catalog-grid { padding: 30px 12px; }
    .grid-layout { gap: 10px; }
    .bundle-card { padding: 15px 12px; }
    
    .featured-badge { top: 12px; right: 12px; font-size: 8px; padding: 3px 8px; }
    .bundle-title { font-size: 18px; margin-bottom: 8px; }
    .bundle-description { font-size: 11px; margin-bottom: 15px; -webkit-line-clamp: 2; }
    .price-current { font-size: 26px; }
    .price-current sup { font-size: 14px; }
    .bundle-pricing { margin-bottom: 20px; }
    .pricing-row { 
      flex-direction: row; 
      flex-wrap: wrap;
      align-items: baseline; 
      gap: 5px; 
    }
    .discount-badge {
      width: 100%;
      margin-top: 4px;
    }
    .btn-primary { padding: 12px; }
  }
</style>
