---
interface Props {
  faq: any[];
}

const { faq } = Astro.props;

// Default FAQ if none provided
const defaultFaq = [
  { q: '¿Cómo se entrega el bundle?', a: 'Recibes acceso directo a una carpeta privada en Google Drive con todos los archivos organizados por volumen.' },
  { q: '¿Es compatible con mi versión de Revit?', a: 'Sí, las familias y plantillas son compatibles con Revit 2018 hasta 2024.' }
];

const displayFaq = faq && faq.length > 0 ? faq : defaultFaq;
---

<section id="faq">
  <div class="section-header fade-up">
    <div class="section-overtitle">— RESOLVIENDO DUDAS —</div>
    <h2>PREGUNTAS <span class="accent-green">FRECUENTES</span></h2>
    <p class="section-sub-faq">Todo lo que necesitas saber antes de dar el siguiente paso.</p>
  </div>
  
  <div class="faq-container">
    {displayFaq.map((item, index) => (
      <div class="faq-item fade-up" style={`transition-delay: ${index * 0.1}s`}>
        <div class="faq-question">
          {item.q}
        </div>
        <div class="faq-answer">
          {item.a}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  #faq {
    padding: 100px 40px; /* Igual al diseño */
    background: #080808;
  }

  .section-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px;
  }

  .section-overtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--green);
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(38px, 6vw, 76px);
    margin-bottom: 16px;
    color: var(--white);
    text-transform: uppercase;
    line-height: 0.9;
  }

  .accent-green {
    color: var(--green);
  }

  .section-sub-faq {
    font-size: 16px;
    color: #888; /* Color del diseño master */
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  .faq-container {
    max-width: 800px; /* Igual al diseño */
    margin: 0 auto;
    text-align: left;
  }

  .faq-item {
    background: #141414; /* var(--card) del diseño */
    border: 1px solid #1e1e1e; /* var(--border) del diseño */
    border-radius: 8px; /* Igual al diseño */
    margin-bottom: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .faq-question {
    padding: 20px 24px; /* Exacto al diseño */
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
    font-size: 15px; /* Exacto al diseño */
    color: var(--white);
  }

  .faq-question::after {
    content: '+';
    color: var(--green);
    font-size: 20px; /* Exacto al diseño */
    transition: 0.3s;
  }

  /* Usamos 'is-open' para no chocar con las animaciones 'active' */
  .faq-item.is-open .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 24px 24px; /* Exacto al diseño */
    display: none;
    color: #888; /* var(--subtle) */
    font-size: 14px;
    line-height: 1.6;
  }

  .faq-item.is-open .faq-answer {
    display: block;
  }

  @media (max-width: 600px) {
    #faq { padding: 40px 20px; }
    .faq-question { padding: 18px 20px; font-size: 14px; }
    .faq-answer { padding: 0 20px 20px; font-size: 13px; }
  }
</style>

<script>
  function initBundleFaq() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      if (question) {
        // Usamos una clase única 'is-open' para NO interferir con las animaciones 'active'
        question.onclick = () => {
          item.classList.toggle('is-open');
        };
      }
    });
  }

  // Ejecución inicial y reactiva
  initBundleFaq();
  document.addEventListener('astro:after-swap', initBundleFaq);
</script>
