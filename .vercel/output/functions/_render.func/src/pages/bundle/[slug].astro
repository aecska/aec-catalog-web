---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/layout/Navbar.astro';
import Footer from '../../components/layout/Footer.astro';
import BundleHero from '../../components/bundles/BundleHero.astro';
import BundleInventory from '../../components/bundles/BundleInventory.astro';
import BundleFinalOffer from '../../components/bundles/BundleFinalOffer.astro';
import BundleFAQ from '../../components/bundles/BundleFAQ.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;

// Fetch full bundle data including related packs
const { data: bundle, error } = await supabase
  .from('bundles')
  .select(`
    *,
    categories (
      name
    ),
    bundle_packs (
      packs (
        *,
        categories (
          name
        )
      )
    )
  `)
  .eq('slug', slug)
  .single();

if (error || !bundle) {
  return Astro.redirect('/404');
}

// Flatten related packs
const relatedPacks = bundle.bundle_packs?.map((bp: any) => bp.packs).filter(Boolean) || [];
---

<Layout title={`${bundle.name} — Ingeniería Extrema Media`}>
  <Navbar />

  <main>
    <!-- 1. MASTER HERO -->
    <BundleHero bundle={bundle} />

    <!-- 2. MASTER INVENTORY -->
    {relatedPacks.length > 0 && (
      <BundleInventory packs={relatedPacks} />
    )}

    <!-- 3. MASTER OFFER -->
    <BundleFinalOffer bundle={bundle} />

    <!-- 4. MASTER FAQ -->
    <BundleFAQ faq={bundle.faq} />
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Base styles for elite sections */
  main {
    background: #080808;
    color: #f5f5f5;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .fade-up.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Intersection Observer script for animations */
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  function initAnimations() {
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  }

  initAnimations();
  document.addEventListener('astro:after-swap', initAnimations);
</script>
